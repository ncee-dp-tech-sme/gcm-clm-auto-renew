# Vault Configuration
# Copy this file to .env and set the VAULT_TOKEN value

# Vault address (default: http://vault:8200)
VAULT_ADDR=http://vault:8200

# Vault root token (obtain from vault-init container logs after first run)
# Run: docker-compose logs vault-init | grep "Root Token:"
VAULT_TOKEN=

# Example:
# VAULT_TOKEN=<your-vault-token>