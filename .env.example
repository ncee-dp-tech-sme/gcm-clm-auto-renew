# Environment variables for Certificate Monitor

# Node.js environment
NODE_ENV=production

# Application port
PORT=3000

# Vault configuration
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Data directories (for Docker)
DATA_DIR=/app/data
CERT_DIR=/app/certs

# Target URL to monitor (optional - can be configured in config.json)
# TARGET_URL=https://example.com