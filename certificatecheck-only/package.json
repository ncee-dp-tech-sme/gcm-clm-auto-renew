{
  "name": "certificatecheck-only",
  "version": "1.0.0",
  "description": "Standalone certificate check app with side-by-side comparison",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:win": "pkg server.js --targets node18-win-x64 --output Dist/certificatecheck-only.exe"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "bin": "server.js",
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "outputPath": "Dist"
  }
}